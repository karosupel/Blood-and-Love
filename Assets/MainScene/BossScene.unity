    - target: {fileID: 1840014530239347126, guid: a553583edd8f4ae46b8883c3c6c0c1c2, type: 3}
      propertyPath: dialogueLibrary.Array.data[13].entries.Array.data[6].text
      value: What?! How?! I killed you!
      objectReference: {fileID: 0}
    - target: {fileID: 1840014530239347126, guid: a553583edd8f4ae46b8883c3c6c0c1c2, type: 3}
      propertyPath: dialogueLibrary.Array.data[13].entries.Array.data[7].text
      value: Clearly not well enough.
      objectReference: {fileID: 0}
    - target: {fileID: 1840014530239347126, guid: a553583edd8f4ae46b8883c3c6c0c1c2, type: 3}
      propertyPath: dialogueLibrary.Array.data[13].entries.Array.data[8].text
      value: "Ugh! Doesn\u2019t matter. I\u2019ll do it again."
      objectReference: {fileID: 0}
    - target: {fileID: 1840014530239347126, guid: a553583edd8f4ae46b8883c3c6c0c1c2, type: 3}
      propertyPath: dialogueLibrary.Array.data[13].entries.Array.data[9].text
      value: "And this time you\u2019re not coming back."
      objectReference: {fileID: 0}
    - target: {fileID: 1840014530239347126, guid: a553583edd8f4ae46b8883c3c6c0c1c2, type: 3}
      propertyPath: dialogueLibrary.Array.data[14].entries.Array.data[1].text
      value: You...
      objectReference: {fileID: 0}
    - target: {fileID: 1840014530239347126, guid: a553583edd8f4ae46b8883c3c6c0c1c2, type: 3}
      propertyPath: dialogueLibrary.Array.data[14].entries.Array.data[2].text
      value: I...
      objectReference: {fileID: 0}
    - target: {fileID: 1840014530239347126, guid: a553583edd8f4ae46b8883c3c6c0c1c2, type: 3}
      propertyPath: dialogueLibrary.Array.data[14].entries.Array.data[3].text
      value: I was sure I lost you.
      objectReference: {fileID: 0}
    - target: {fileID: 1840014530239347126, guid: a553583edd8f4ae46b8883c3c6c0c1c2, type: 3}
      propertyPath: dialogueLibrary.Array.data[18].entries.Array.data[0].text
      value: NO! I will not be defeated by a lowly monster.
      objectReference: {fileID: 0}
    - target: {fileID: 1840014530239347126, guid: a553583edd8f4ae46b8883c3c6c0c1c2, type: 3}
      propertyPath: dialogueLibrary.Array.data[19].entries.Array.data[0].text
